      },
      "streamSettings": {
        "network": "ws",
        "sockopt": {
          "acceptProxyProtocol": true
        },
        "wsSettings": {
          "path": "/vless-ntls"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      },
      "tag": "vless-ws-ntls"
